# =========================
# GLOBAL
# =========================
ENV=production

# =========================
# REDIS
# =========================
REDIS_HOST=redis
REDIS_PORT=6379

# =========================
# API SERVICE (FastAPI)
# =========================
API_HOST=0.0.0.0
API_PORT=8000

# Queue name used by API + Worker
QUEUE_NAME=jobs

# =========================
# WORKER SERVICE
# =========================
WORKER_CONCURRENCY=1

# =========================
# FRONTEND (Node.js)
# =========================
FRONTEND_PORT=3000

# URL the frontend uses to talk to API
API_URL=http://api:8000

# =========================
# OPTIONAL
# =========================
LOG_LEVEL=info